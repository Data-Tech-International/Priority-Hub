{
  "mcpServers": {
    "context7": {
      "type": "http",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "${CONTEXT7_API_KEY}"
      },
      "tools": [
        "query-docs",
        "resolve-library-id",
        "check-security-advisory",
        "get-remediation-path"
      ]
    },
    "github": {
      "type": "github",
      "tools": [
        "create-issue",
        "create-pull-request",
        "add-pr-comment",
        "list-workflows"
      ]
    }
  },
  "agents": {
    "security": {
      "mcp_required": ["context7"],
      "capabilities": [
        "resolve-library-id for CVE lookups",
        "check-security-advisory for package advisories",
        "get-remediation-path for dependency updates"
      ]
    },
    "static-analysis": {
      "mcp_optional": ["context7"],
      "capabilities": [
        "query-docs for architectural patterns",
        "resolve-library-id for design best practices"
      ]
    },
    "test-coverage": {
      "mcp_optional": ["context7"],
      "capabilities": [
        "query-docs for testing best practices and patterns"
      ]
    },
    "spec-planner": {
      "mcp_optional": ["context7", "github"],
      "capabilities": [
        "query-docs for architecture and planning best practices",
        "create-issue for implementation handoff",
        "create-pull-request for branch to PR bootstrap"
      ]
    },
    "implementation-orchestrator": {
      "mcp_required": ["github"],
      "capabilities": [
        "create-issue for implementation execution",
        "create-pull-request for draft implementation PR",
        "add-pr-comment for handoff and status updates"
      ]
    }
  }
}
