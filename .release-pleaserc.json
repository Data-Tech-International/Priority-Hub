{
  "release-type": "simple",
  "packages": {
    ".": {
      "release-type": "simple",
      "changelog-path": "CHANGELOG.md"
    }
  },
  "extra-files": [
    {
      "type": "xml",
      "file": "backend/Directory.Build.props",
      "updaters": [
        {
          "type": "xml",
          "xpath": "//Version",
          "version-key": "."
        },
        {
          "type": "xml",
          "xpath": "//AssemblyVersion",
          "version-key": "."
        },
        {
          "type": "xml",
          "xpath": "//FileVersion",
          "version-key": "."
        },
        {
          "type": "xml",
          "xpath": "//InformationalVersion",
          "version-key": "."
        }
      ]
    }
  ]
}
