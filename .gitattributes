# Auto detect text files and normalize line endings to LF for all files
* text=auto eol=lf

# Source code
*.cs text
*.jsx text
*.js text
*.json text
*.md text
*.yaml text
*.yml text
*.xml text

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.zip binary
*.dll binary
*.exe binary
*.pdb binary

# Always use LF for shell scripts
*.sh text eol=lf
*.bash text eol=lf

# PowerShell with CRLF
*.ps1 text eol=crlf
