<Project>

  <!--
    Version is kept in sync with the root package.json "version" field.
    Update both files together for every release following Semantic Versioning.
  -->
  <PropertyGroup>
    <Version>0.2.0</Version>
    <AssemblyVersion>0.2.0.0</AssemblyVersion>
    <FileVersion>0.2.0.0</FileVersion>
    <InformationalVersion>0.2.0</InformationalVersion>
  </PropertyGroup>

</Project>
