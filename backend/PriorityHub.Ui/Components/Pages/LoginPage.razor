@page "/login"
@attribute [AllowAnonymous]

<PageTitle>Sign in — Priority Hub</PageTitle>

<div class="app-shell">
    <main class="login-page">
        <section class="login-card">
            <p class="eyebrow">Priority Hub</p>
            <h1 style="border:none;box-shadow:none;">Sign in to access your unified priority dashboard.</h1>
            <p class="login-copy">
                Use any provider below to unlock the workspace. Microsoft sign-in can also be used for Azure DevOps connections without storing a PAT.
            </p>

            @if (!string.IsNullOrWhiteSpace(Error))
            {
                <section class="status-banner status-error">
                    <strong>Authentication check failed.</strong>
                    <span>@Error</span>
                </section>
            }

            <div class="login-actions">
                <a class="login-provider-button microsoft" href="/api/auth/login/microsoft">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none"><rect width="24" height="24" fill="#F25022"/><rect x="12" width="12" height="12" fill="#7FBA00"/><rect y="12" width="12" height="12" fill="#00A4EF"/><rect x="12" y="12" width="12" height="12" fill="#FFB900"/></svg>
                    <span style="margin-left:10px;">Sign in with Microsoft</span>
                </a>
                <a class="login-provider-button github" href="/api/auth/login/github">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none"><path fill="#fff" d="M12 2C6.48 2 2 6.58 2 12.26c0 4.48 2.87 8.28 6.84 9.63.5.09.68-.22.68-.48 0-.24-.01-.87-.01-1.7-2.78.62-3.37-1.36-3.37-1.36-.45-1.18-1.1-1.5-1.1-1.5-.9-.63.07-.62.07-.62 1 .07 1.53 1.05 1.53 1.05.89 1.56 2.34 1.11 2.91.85.09-.66.35-1.11.63-1.37-2.22-.26-4.56-1.14-4.56-5.07 0-1.12.39-2.03 1.03-2.75-.1-.26-.45-1.3.1-2.7 0 0 .84-.28 2.75 1.05A9.38 9.38 0 0 1 12 6.84c.85.004 1.71.12 2.51.35 1.91-1.33 2.75-1.05 2.75-1.05.55 1.4.2 2.44.1 2.7.64.72 1.03 1.63 1.03 2.75 0 3.94-2.34 4.81-4.57 5.07.36.32.68.94.68 1.9 0 1.37-.01 2.47-.01 2.81 0 .26.18.57.69.48A10.01 10.01 0 0 0 22 12.26C22 6.58 17.52 2 12 2Z"/></svg>
                    <span style="margin-left:10px;">Sign in with GitHub</span>
                </a>
                <a class="login-provider-button jira" href="/api/auth/login/jira">
                    <img src="/icons/jira.svg" alt="Jira" width="22" height="22" style="margin-right:10px;" />Sign in with Jira
                </a>
                <a class="login-provider-button yandex" href="/api/auth/login/yandex">
                    <img src="/icons/yandex.svg" alt="Yandex" width="22" height="22" style="margin-right:10px;" />Sign in with Yandex
                </a>
                <a class="login-provider-button trello" href="/api/auth/login/trello">
                    <img src="/icons/trello.svg" alt="Trello" width="22" height="22" style="margin-right:10px;" />Sign in with Trello
                </a>
                <a class="login-provider-button google" href="/api/auth/login/google">
                    <img src="/icons/google.svg" alt="Google" width="22" height="22" style="margin-right:10px;" />Sign in with Google
                </a>
                <a class="login-provider-button facebook" href="/api/auth/login/facebook">
                    <img src="/icons/facebook.svg" alt="Facebook" width="22" height="22" style="margin-right:10px;" />Sign in with Facebook
                </a>
            </div>
        </section>
    </main>
</div>

@code {
    [SupplyParameterFromQuery(Name = "error")]
    public string? Error { get; set; }
}
