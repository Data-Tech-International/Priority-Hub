@page "/login"
@attribute [AllowAnonymous]

<PageTitle>Sign in — Priority Hub</PageTitle>

<div class="app-shell">
    <main class="login-page">
        <section class="login-card">
            <p class="eyebrow">Priority Hub</p>
            <h1 class="login-heading">Sign in to access your unified priority dashboard.</h1>
            <p class="login-copy">
                Use Microsoft or GitHub to unlock the workspace. Microsoft sign-in
                can also be used for Azure DevOps connections without storing a PAT.
            </p>

            @if (!string.IsNullOrWhiteSpace(Error))
            {
                <section class="status-banner status-error">
                    <strong>Authentication check failed.</strong>
                    <span>@Error</span>
                </section>
            }

            <div class="login-actions">
                <a class="login-provider-button microsoft" href="/api/auth/login/microsoft">
                    <svg class="provider-icon" viewBox="0 0 21 21" aria-hidden="true"><rect x="1" y="1" width="9" height="9" fill="#f25022"/><rect x="11" y="1" width="9" height="9" fill="#7fba00"/><rect x="1" y="11" width="9" height="9" fill="#00a4ef"/><rect x="11" y="11" width="9" height="9" fill="#ffb900"/></svg>
                    Sign in with Microsoft
                </a>
                <a class="login-provider-button github" href="/api/auth/login/github">
                    <svg class="provider-icon" viewBox="0 0 24 24" aria-hidden="true" fill="currentColor"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
                    Sign in with GitHub
                </a>
                <a class="login-provider-button google" href="/api/auth/login/google">
                    <svg class="provider-icon" viewBox="0 0 24 24" aria-hidden="true"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
                    Sign in with Google
                </a>
                <a class="login-provider-button jira" href="/api/auth/login/jira">
                    <svg class="provider-icon" viewBox="0 0 24 24" aria-hidden="true" fill="none"><path d="M11.975 0C9.12 0 6.637 2.123 6.637 4.978V6.64H2.04C2.04 9.495 4.163 11.617 7.017 11.617h1.664v1.662C8.68 16.134 10.803 18.256 13.657 18.256V6.64h5.594V4.978C19.25 2.123 16.768 0 13.913 0h-1.938zM13.698 6.637v5.594h5.594V6.637H13.698z" fill="#2684FF"/><path d="M13.698 6.637C13.698 9.491 15.82 11.614 18.675 11.614h1.662v1.662C20.337 16.131 18.215 18.254 15.36 18.254v-5.596h-1.662V6.637z" fill="url(#jira_grad)"/><defs><linearGradient id="jira_grad" x1="13.698" y1="9.18" x2="20.337" y2="9.18" gradientUnits="userSpaceOnUse"><stop stop-color="#0052CC"/><stop offset="1" stop-color="#2684FF"/></linearGradient></defs></svg>
                    Sign in with Jira
                </a>
                <a class="login-provider-button trello" href="/api/auth/login/trello">
                    <svg class="provider-icon" viewBox="0 0 24 24" aria-hidden="true" fill="currentColor"><path d="M21 0H3C1.343 0 0 1.343 0 3v18c0 1.657 1.343 3 3 3h18c1.657 0 3-1.343 3-3V3c0-1.657-1.343-3-3-3zM10.44 18.18a1.56 1.56 0 0 1-1.56 1.56H4.56A1.56 1.56 0 0 1 3 18.18V5.56A1.56 1.56 0 0 1 4.56 4h4.32A1.56 1.56 0 0 1 10.44 5.56v12.62zm10.56-6a1.56 1.56 0 0 1-1.56 1.56h-4.32A1.56 1.56 0 0 1 13.56 12.18V5.56A1.56 1.56 0 0 1 15.12 4h4.32A1.56 1.56 0 0 1 21 5.56v6.62z"/></svg>
                    Sign in with Trello
                </a>
                <a class="login-provider-button yandex" href="/api/auth/login/yandex">
                    <svg class="provider-icon" viewBox="0 0 24 24" aria-hidden="true" fill="currentColor"><path d="M2.04 12C2.04 6.477 6.477 2.04 12 2.04S21.96 6.477 21.96 12 17.523 21.96 12 21.96 2.04 17.523 2.04 12zm11.02-6.432H12c-2.175 0-3.5 1.132-3.5 3.012 0 1.67.83 2.61 2.305 3.56L9.1 14.952H7.212l-.001.001v1.479H9.95l-1.33 2h1.95l1.33-2h.004V9.056c0-1.066.53-1.67 1.534-1.67h.62V5.568z"/></svg>
                    Sign in with Yandex
                </a>
                <a class="login-provider-button facebook" href="/api/auth/login/facebook">
                    <svg class="provider-icon" viewBox="0 0 24 24" aria-hidden="true" fill="currentColor"><path d="M24 12.073C24 5.404 18.627 0 12 0S0 5.404 0 12.073C0 18.1 4.388 23.094 10.125 24v-8.437H7.078v-3.49h3.047V9.41c0-3.025 1.792-4.697 4.533-4.697 1.312 0 2.686.236 2.686.236v2.97h-1.513c-1.491 0-1.956.93-1.956 1.886v2.267h3.328l-.532 3.49h-2.796V24C19.612 23.094 24 18.1 24 12.073z"/></svg>
                    Sign in with Facebook
                </a>
            </div>
        </section>
    </main>
</div>

@code {
    [SupplyParameterFromQuery(Name = "error")]
    public string? Error { get; set; }
}
