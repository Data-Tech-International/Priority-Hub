@page "/settings"
@attribute [Authorize]
@rendermode InteractiveServer
@inject IConfigStore ConfigStore
@inject ConnectorRegistry ConnectorRegistry
@inject IHttpContextAccessor HttpContextAccessor
@inject PassphraseCacheInterop PassphraseCache
@inject IJSRuntime JS
@inject NavigationManager Navigation

<PageTitle>Settings — Priority Hub</PageTitle>

<div class="app-shell">
    <div class="settings-page">
        <div class="settings-header">
            <p class="eyebrow">Priority Hub</p>
            <h1>Settings</h1>
            <p>Manage connector configuration, account, and data export.</p>
        </div>

        @if (_statusMessage is not null)
        {
            <section class="status-banner @(_statusIsError ? "status-error" : "status-info")" role="status" aria-live="polite">
                <span>@_statusMessage</span>
                <button class="status-dismiss" type="button" @onclick="DismissStatus" aria-label="Dismiss notification">✕</button>
            </section>
        }

        <div class="settings-tabs" role="tablist" aria-label="Settings sections" @onkeydown="HandleTabKeyDown">
            @foreach (var tabDef in TabDefs)
            {
                var isActive = _activeTab == tabDef.Key;
                <button type="button"
                        class="settings-tab@(isActive ? " is-active" : "")"
                        role="tab"
                        aria-selected="@isActive"
                        aria-controls="tabpanel-@tabDef.Key"
                        id="tab-@tabDef.Key"
                        tabindex="@(isActive ? 0 : -1)"
                        @onclick="() => SwitchTabAsync(tabDef.Key)">
                    <span class="settings-tab-icon" aria-hidden="true">@tabDef.Icon</span>
                    <span>@tabDef.Label</span>
                </button>
            }
        </div>

        @* ── Connectors tab ── *@
        @if (_activeTab == "connectors")
        {
            <div class="settings-tab-content" id="tabpanel-connectors" role="tabpanel" aria-labelledby="tab-connectors">
                @if (_loadingConfig)
                {
                    <div class="settings-loading" aria-live="polite" aria-busy="true">
                        <span class="settings-spinner" aria-hidden="true"></span>
                        <span>Loading configuration…</span>
                    </div>
                }
                else if (_connectorMetadata.Count == 0)
                {
                    <p>No connector types registered.</p>
                }
                else
                {
                    @foreach (var connector in _connectorMetadata)
                    {
                        var configKey = ToConfigKey(connector.ProviderKey);
                        var connections = GetConnections(configKey);
                        var helpKey = $"settings.connectors.{connector.ProviderKey}";
                        var isExpanded = _expandedConnectors.Contains(connector.ProviderKey);

                        <section class="provider-config-block">
                            <button type="button"
                                    class="provider-config-toggle"
                                    @onclick="() => ToggleConnectorSection(connector.ProviderKey)"
                                    aria-expanded="@isExpanded"
                                    aria-controls="connector-content-@connector.ProviderKey">
                                <div class="provider-config-toggle-info">
                                    <div class="provider-config-toggle-title">
                                        <span class="connector-emoji" aria-hidden="true">@connector.DefaultEmoji</span>
                                        <strong>@connector.DisplayName</strong>
                                    </div>
                                    <span class="provider-config-summary">@connector.Description</span>
                                    @if (!isExpanded)
                                    {
                                        <span class="provider-config-connection-count">
                                            @(connections.Count == 0
                                                ? "No connections configured"
                                                : connections.Count == 1
                                                    ? $"1 connection: {(GetConnectionField(connections[0], "name") is string n && n.Length > 0 ? n : "Connection 1")}"
                                                    : $"{connections.Count} connections configured")
                                        </span>
                                    }
                                </div>
                                <span class="provider-config-chevron" aria-hidden="true">@(isExpanded ? "▲" : "▼")</span>
                            </button>

                            @if (isExpanded)
                            {
                                <div class="provider-config-content" id="connector-content-@connector.ProviderKey">
                                    @if (HelpContent.Entries.TryGetValue(helpKey, out var help))
                                    {
                                        <HelpPanel ContextKey="@helpKey" Title="@help.Title">
                                            @foreach (var line in help.Body)
                                            {
                                                <p>@line</p>
                                            }
                                        </HelpPanel>
                                    }

                                    <div class="connection-editor-list">
                                        @for (var idx = 0; idx < connections.Count; idx++)
                                        {
                                            var index = idx;
                                            var connection = connections[index];

                                            <article class="connection-editor-card">
                                                <div class="connection-editor-header">
                                                    <div class="connection-editor-title">
                                                        <EmojiPicker Value="@(GetConnectionField(connection, EmojiField) ?? connector.DefaultEmoji)"
                                                                     OnEmojiSelected="emoji => SetConnectionField(configKey, index, EmojiField, emoji)" />
                                                        <strong>@(GetConnectionField(connection, "name") is string n && n.Length > 0 ? n : $"Connection {index + 1}")</strong>
                                                    </div>
                                                    <button class="remove-button" type="button"
                                                            @onclick="() => RemoveConnectionWithConfirmAsync(configKey, index)"
                                                            aria-label="@($"Remove {(GetConnectionField(connection, "name") is string cn && cn.Length > 0 ? cn : $"connection {index + 1}")}")">
                                                        Remove
                                                    </button>
                                                </div>

                                                <label class="toggle-row">
                                                    <input type="checkbox"
                                                           checked="@(GetConnectionEnabled(connection))"
                                                           @onchange="e => SetConnectionField(configKey, index, EnabledField, e.Value)" />
                                                    <span>Enabled</span>
                                                </label>

                                                <div class="config-grid">
                                                    @foreach (var field in connector.ConfigFields)
                                                    {
                                                        var fieldError = GetFieldError(configKey, index, field.Key);
                                                        var isWide = field.InputKind == "textarea";

                                                        @if (field.InputKind == "checkbox")
                                                        {
                                                            <label class="toggle-row">
                                                                <input type="checkbox"
                                                                       checked="@(IsCheckboxChecked(connection, field.Key))"
                                                                       @onchange="e => SetConnectionField(configKey, index, field.Key, e.Value)" />
                                                                <span>@field.Label</span>
                                                            </label>
                                                        }
                                                        else @if (isWide)
                                                        {
                                                            <label class="config-field config-field-wide@(fieldError is not null ? " config-field-error" : "")">
                                                                <span>@field.Label</span>
                                                                <textarea value="@(GetConnectionField(connection, field.Key) ?? "")"
                                                                          @onchange="e => SetConnectionField(configKey, index, field.Key, e.Value)"
                                                                          rows="4"></textarea>
                                                                @if (fieldError is not null)
                                                                {
                                                                    <small role="alert">@fieldError</small>
                                                                }
                                                            </label>
                                                        }
                                                        else
                                                        {
                                                            <label class="config-field@(fieldError is not null ? " config-field-error" : "")">
                                                                <span>@field.Label</span>
                                                                <input type="@(field.InputKind == "password" ? "password" : "text")"
                                                                       value="@(GetConnectionField(connection, field.Key) ?? "")"
                                                                       @onchange="e => SetConnectionField(configKey, index, field.Key, e.Value)" />
                                                                @if (fieldError is not null)
                                                                {
                                                                    <small role="alert">@fieldError</small>
                                                                }
                                                            </label>
                                                        }
                                                    }
                                                </div>

                                                @* Microsoft Account selector for Outlook and Tasks connections *@
                                                @if (connector.ProviderKey is "outlook-flagged-mail" or "microsoft-tasks")
                                                {
                                                    var linkedAccountOptions = GetLinkedAccountOptions();
                                                    <div class="config-grid" style="margin-top:8px">
                                                        <label class="config-field">
                                                            <span>Microsoft Account</span>
                                                            <select value="@(GetConnectionField(connection, "linkedAccountId") ?? "")"
                                                                    @onchange="@(e => SetConnectionField(configKey, index, "linkedAccountId", e.Value))">
                                                                <option value="">Primary (login)</option>
                                                                @foreach (var (id, label) in linkedAccountOptions)
                                                                {
                                                                    <option value="@id">@label</option>
                                                                }
                                                            </select>
                                                        </label>
                                                    </div>
                                                }
                                            </article>
                                        }
                                    </div>

                                    <div class="provider-config-footer">
                                        <button class="add-button" type="button" @onclick="() => AddConnection(connector)">
                                            + Add connection
                                        </button>
                                    </div>
                                </div>
                            }
                        </section>
                    }

                    <div class="settings-save-footer">
                        @if (_hasUnsavedChanges)
                        {
                            <span class="unsaved-indicator" aria-live="polite">Unsaved changes</span>
                        }
                        <button class="refresh-button" type="button"
                                @onclick="SaveConfiguration"
                                disabled="@(_savingConfig || _loadingConfig)">
                            @if (_savingConfig)
                            {
                                <span class="button-spinner" aria-hidden="true"></span>
                                @:Saving…
                            }
                            else
                            {
                                @:Save connector configuration
                            }
                        </button>
                    </div>
                }
            </div>
        }
        @* ── Account tab ── *@
        @if (_activeTab == "account")
        {
            <div class="settings-tab-content" id="tabpanel-account" role="tabpanel" aria-labelledby="tab-account">
                <div class="account-card">
                    <AuthorizeView>
                        <Authorized>
                            @{
                                var userName = context.User.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value;
                                var userEmail = context.User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value;
                                var userPicture = context.User.FindFirst("picture")?.Value;
                                var userProvider = context.User.FindFirst("provider")?.Value ?? "";
                            }
                            <div class="account-user-row">
                                @if (!string.IsNullOrWhiteSpace(userPicture))
                                {
                                    <img class="nav-avatar" src="@userPicture" alt="@(userName ?? userEmail ?? "User")" style="width:56px;height:56px" />
                                }
                                else
                                {
                                    <span class="nav-avatar nav-avatar-fallback" style="width:56px;height:56px;font-size:1.4rem">
                                        @((userName ?? userEmail ?? "U")[..1].ToUpperInvariant())
                                    </span>
                                }
                                <div>
                                    <strong>@(userName ?? userEmail ?? "Signed in")</strong>
                                    <span>
                                        @userEmail
                                        @if (!string.IsNullOrWhiteSpace(userProvider))
                                        {
                                            @($" · {WorkItemRanker.FormatProviderName(userProvider)}")
                                        }
                                    </span>
                                </div>
                            </div>
                            <form method="post" action="/api/auth/logout">
                                <AntiforgeryToken />
                                <button class="signout-button" type="submit" style="margin-top:16px">
                                    Sign out
                                </button>
                            </form>

                            @* ── Linked Microsoft Accounts ── *@
                            @if (string.Equals(userProvider, "microsoft", StringComparison.OrdinalIgnoreCase) ||
                                 _config.LinkedMicrosoftAccounts.Count > 0)
                            {
                                <div class="provider-config-block" style="margin-top:24px">
                                    <h3 style="margin:0 0 12px">Linked Microsoft Accounts</h3>
                                    <p class="provider-config-summary" style="margin-bottom:16px">
                                        Link additional Microsoft accounts to use with Outlook Flagged Mail and Microsoft Tasks connectors.
                                    </p>

                                    @if (_linkedAccountsLoading)
                                    {
                                        <div class="settings-loading" aria-live="polite" aria-busy="true">
                                            <span class="settings-spinner" aria-hidden="true"></span>
                                            <span>Loading linked accounts…</span>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="connection-editor-list">
                                            @* Primary account always appears first *@
                                            <article class="connection-editor-card">
                                                <div class="connection-editor-header">
                                                    <div class="connection-editor-title">
                                                        <span aria-hidden="true">🏠</span>
                                                        <strong>@(userName ?? userEmail ?? "Primary account")</strong>
                                                    </div>
                                                    <span class="provider-config-summary">Primary (login) · Cannot be removed</span>
                                                </div>
                                                <span style="font-size:0.85rem;color:var(--text-muted)">@userEmail</span>
                                            </article>

                                            @foreach (var linked in _config.LinkedMicrosoftAccounts)
                                            {
                                                var linkedId = linked.Id;
                                                <article class="connection-editor-card">
                                                    <div class="connection-editor-header">
                                                        <div class="connection-editor-title">
                                                            <span aria-hidden="true">🔗</span>
                                                            <strong>@(linked.DisplayName is { Length: > 0 } n ? n : linked.Email)</strong>
                                                        </div>
                                                        <button class="remove-button" type="button"
                                                                @onclick="() => RemoveLinkedAccountAsync(linkedId)"
                                                                aria-label="Remove linked account @linked.Email">
                                                            Remove
                                                        </button>
                                                    </div>
                                                    <span style="font-size:0.85rem;color:var(--text-muted)">
                                                        @linked.Email · Linked @linked.LinkedAt.ToString("MMM d, yyyy")
                                                    </span>
                                                </article>
                                            }
                                        </div>

                                        <div style="margin-top:16px">
                                            <a href="/api/auth/link/microsoft" class="add-connection-button">
                                                + Link Microsoft Account
                                            </a>
                                        </div>
                                    }
                                </div>
                            }
                        </Authorized>
                    </AuthorizeView>
                </div>
            </div>
        }

        @* ── Import / Export tab ── *@
        @if (_activeTab == "export")
        {
            <div class="settings-tab-content" id="tabpanel-export" role="tabpanel" aria-labelledby="tab-export">
                @if (HelpContent.Entries.TryGetValue("settings.export", out var exportHelp))
                {
                    <HelpPanel ContextKey="settings.export" Title="@exportHelp.Title">
                        @foreach (var line in exportHelp.Body)
                        {
                            <p>@line</p>
                        }
                    </HelpPanel>
                }

                <div class="export-section">
                    <article class="export-card">
                        <h3>Export connector configuration</h3>
                        <p>
                            Downloads your connector settings as JSON. PATs and tokens are replaced with masked placeholders
                            before download.
                        </p>
                        <button class="refresh-button" type="button" @onclick="ExportConfig">
                            Download configuration
                        </button>
                    </article>

                    <article class="export-card">
                        <h3>Import connector configuration</h3>
                        <p>
                            Upload a previously exported JSON file to merge connector settings. Existing connections
                            are matched by ID — matching IDs are updated, new IDs are added, and connections missing
                            from the file are left unchanged.
                        </p>
                        <label class="import-file-label">
                            <InputFile OnChange="HandleImportFileSelected" accept=".json" class="import-file-input" />
                            <span class="refresh-button" aria-hidden="true">Choose file…</span>
                        </label>
                        @if (_importError is not null)
                        {
                            <p class="import-error" role="alert">@_importError</p>
                        }
                    </article>
                </div>

                @if (_importPreview is not null)
                {
                    <div class="import-preview" role="region" aria-label="Import preview">
                        <h3>Import preview</h3>

                        <div class="import-preview-summary">
                            @{ var addCount = _importPreview.Count(p => p.Action == ImportAction.Add); }
                            @{ var updateCount = _importPreview.Count(p => p.Action == ImportAction.Update); }
                            @{ var unchangedCount = _importPreview.Count(p => p.Action == ImportAction.Unchanged); }
                            @if (addCount > 0)
                            {
                                <span class="import-badge import-badge-add">@addCount added</span>
                            }
                            @if (updateCount > 0)
                            {
                                <span class="import-badge import-badge-update">@updateCount updated</span>
                            }
                            @if (unchangedCount > 0)
                            {
                                <span class="import-badge import-badge-unchanged">@unchangedCount unchanged</span>
                            }
                        </div>

                        @if (_importPreview.Any(p => p.HasMaskedSecrets))
                        {
                            <p class="import-masked-warning">
                                ⚠️ Secrets (PATs, API tokens) from the exported file may be masked with <code>********</code>
                                and will overwrite current values. Re-enter secrets after import.
                            </p>
                        }

                        <table class="import-preview-table" aria-label="Connections to be imported">
                            <thead>
                                <tr>
                                    <th scope="col">Connection</th>
                                    <th scope="col">Provider</th>
                                    <th scope="col">Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var entry in _importPreview)
                                {
                                    <tr>
                                        <td>@entry.Name</td>
                                        <td>@entry.Provider</td>
                                        <td>
                                            <span class="import-action import-action-@entry.Action.ToString().ToLowerInvariant()">
                                                @entry.Action.ToString().ToLowerInvariant()
                                            </span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>

                        <div class="import-preview-actions">
                            <button class="refresh-button" type="button" @onclick="ApplyImportAsync">
                                Confirm import
                            </button>
                            <button class="remove-button" type="button" @onclick="CancelImport">
                                Cancel
                            </button>
                        </div>
                    </div>
                }
            </div>
        }

        @* ── Security tab ── *@
        @if (_activeTab == "security")
        {
            <div class="settings-tab-content" id="tabpanel-security" role="tabpanel" aria-labelledby="tab-security">
                <div class="security-section">
                    <article class="security-card">
                        <h3>Remembered unlock</h3>
                        <p>
                            When you unlock on a trusted device and choose to be remembered, the app stores
                            wrapped unlock material in your browser using WebCrypto AES-GCM. The raw
                            passphrase is never sent to the server.
                        </p>

                        @if (_checkingCache)
                        {
                            <p class="security-cache-status">Checking remembered state…</p>
                        }
                        else if (_hasCachedPassphrase)
                        {
                            <p class="security-cache-status is-active">
                                A remembered unlock is currently active on this browser.
                            </p>
                            <button class="remove-button"
                                    type="button"
                                    disabled="@_clearingCache"
                                    @onclick="ClearPassphraseCacheAsync">
                                @(_clearingCache ? "Clearing…" : "Clear remembered unlock")
                            </button>
                        }
                        else
                        {
                            <p class="security-cache-status">
                                No remembered unlock is active on this browser.
                            </p>
                        }
                    </article>
                </div>
            </div>
        }
    </div>
</div>

@code {
    private const string EnabledField = "enabled";
    private const string EmojiField = "emoji";
    private string _activeTab = "connectors";
    private bool _loadingConfig = true;
    private bool _savingConfig;
    private string? _statusMessage;
    private bool _statusIsError;
    private bool _hasUnsavedChanges;
    private readonly HashSet<string> _expandedConnectors = [];

    private static readonly (string Key, string Icon, string Label)[] TabDefs =
    [
        ("connectors", "🔌", "Connectors"),
        ("account", "👤", "Account"),
        ("export", "📤", "Import / Export"),
        ("security", "🔒", "Security"),
    ];

    // Connector metadata from the registry
    private List<ConnectorMeta> _connectorMetadata = [];

    // Configuration stored as a dictionary of config key -> list of dictionary connections
    private ProviderConfiguration _config = new();
    private Dictionary<string, List<Dictionary<string, object?>>> _connections = new();
    private Dictionary<string, List<Dictionary<string, string?>>> _validationErrors = new();

    // Security tab state
    private bool _checkingCache = false;
    private bool _hasCachedPassphrase = false;
    private bool _clearingCache = false;

    // Linked accounts state
    private bool _linkedAccountsLoading = false;

    // Import state
    private List<ImportPreviewEntry>? _importPreview;
    private ProviderConfiguration? _pendingImportConfig;
    private string? _importError;

    protected override async Task OnInitializedAsync()
    {
        // Check for onboarding redirect
        var uri = new Uri(Navigation.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
        if (query["onboarding"] == "true")
        {
            _statusMessage = "Welcome to Priority Hub! Configure your first connector below to get started.";
            _statusIsError = false;
        }

        // Load connector metadata from registry
        _connectorMetadata = ConnectorRegistry.GetAll().Select(c => new ConnectorMeta(
            c.ProviderKey, c.DisplayName, c.Description, c.DefaultEmoji, c.ConfigFields)).ToList();

        // Load configuration
        var httpContext = HttpContextAccessor.HttpContext;
        if (httpContext is null) return;

        var userId = GetUserIdentityKey(httpContext.User);
        try
        {
            _config = await ConfigStore.LoadAsync(userId, CancellationToken.None);
            RebuildConnectionsDictionary();
        }
        catch (Exception ex)
        {
            _statusMessage = ex.Message;
            _statusIsError = true;
        }
        finally
        {
            _loadingConfig = false;
        }
    }

    private void RebuildConnectionsDictionary()
    {
        _connections = new Dictionary<string, List<Dictionary<string, object?>>>();
        foreach (var connector in _connectorMetadata)
        {
            var key = ToConfigKey(connector.ProviderKey);
            var list = new List<Dictionary<string, object?>>();
            foreach (var jsonElement in _config.GetConnections(connector.ProviderKey))
            {
                var dict = new Dictionary<string, object?>();
                foreach (var prop in jsonElement.EnumerateObject())
                {
                    dict[prop.Name] = prop.Value.ValueKind switch
                    {
                        System.Text.Json.JsonValueKind.String => prop.Value.GetString(),
                        System.Text.Json.JsonValueKind.True => true,
                        System.Text.Json.JsonValueKind.False => false,
                        System.Text.Json.JsonValueKind.Number => prop.Value.GetInt32(),
                        _ => prop.Value.ToString()
                    };
                }
                list.Add(dict);
            }
            _connections[key] = list;
        }
    }

    private List<Dictionary<string, object?>> GetConnections(string configKey) =>
        _connections.TryGetValue(configKey, out var list) ? list : [];

    private void DismissStatus() => _statusMessage = null;

    private void ToggleConnectorSection(string providerKey)
    {
        if (!_expandedConnectors.Remove(providerKey))
            _expandedConnectors.Add(providerKey);
    }

    private async Task HandleTabKeyDown(KeyboardEventArgs e)
    {
        var tabKeys = TabDefs.Select(t => t.Key).ToArray();
        var currentIndex = Array.IndexOf(tabKeys, _activeTab);
        var newIndex = e.Key switch
        {
            "ArrowRight" => (currentIndex + 1) % tabKeys.Length,
            "ArrowLeft" => (currentIndex - 1 + tabKeys.Length) % tabKeys.Length,
            "Home" => 0,
            "End" => tabKeys.Length - 1,
            _ => -1
        };

        if (newIndex >= 0 && newIndex != currentIndex)
        {
            await SwitchTabAsync(tabKeys[newIndex]);
            await JS.InvokeVoidAsync("PriorityHub.focusById", $"tab-{tabKeys[newIndex]}");
        }
    }

    private async Task SwitchTabAsync(string tab)
    {
        _activeTab = tab;

        if (tab == "security")
        {
            _checkingCache = true;
            StateHasChanged();
            try
            {
                _hasCachedPassphrase = await PassphraseCache.HasValidCacheAsync();
            }
            catch
            {
                _hasCachedPassphrase = false;
            }
            finally
            {
                _checkingCache = false;
            }
        }
    }

    private async Task ClearPassphraseCacheAsync()
    {
        _clearingCache = true;
        _statusMessage = null;
        StateHasChanged();
        try
        {
            await PassphraseCache.ClearPassphraseAsync();
            _hasCachedPassphrase = false;
            _statusMessage = "Remembered unlock cleared.";
            _statusIsError = false;
        }
        catch (Exception ex)
        {
            _statusMessage = ex.Message;
            _statusIsError = true;
        }
        finally
        {
            _clearingCache = false;
        }
    }

    private static string? GetConnectionField(Dictionary<string, object?> connection, string field) =>
        connection.TryGetValue(field, out var val) ? val?.ToString() : null;

    private static bool GetConnectionEnabled(Dictionary<string, object?> connection) =>
        !connection.TryGetValue("enabled", out var val) || val is not false;

    private static bool IsCheckboxChecked(Dictionary<string, object?> connection, string field) =>
        connection.TryGetValue(field, out var val) && val is true or "true" or "True";

    private void SetConnectionField(string configKey, int index, string field, object? value)
    {
        if (_connections.TryGetValue(configKey, out var list) && index < list.Count)
        {
            if (field == "enabled" || IsCheckboxField(configKey, field))
            {
                list[index][field] = value is true or "True" or "true";
            }
            else
            {
                list[index][field] = value?.ToString();
            }

            // Inline validation for text/password fields on change
            if (field != "enabled" && field != EmojiField && !IsCheckboxField(configKey, field))
            {
                ValidateFieldInline(configKey, index, field);
            }
            else if (_validationErrors.TryGetValue(configKey, out var errors) && index < errors.Count)
            {
                errors[index].Remove(field);
            }
        }
        _hasUnsavedChanges = true;
    }

    private bool IsCheckboxField(string configKey, string fieldKey)
    {
        var connector = _connectorMetadata.FirstOrDefault(c => ToConfigKey(c.ProviderKey) == configKey);
        return connector?.ConfigFields.Any(f => f.Key == fieldKey && f.InputKind == "checkbox") ?? false;
    }

    private void ValidateFieldInline(string configKey, int index, string fieldKey)
    {
        var connector = _connectorMetadata.FirstOrDefault(c => ToConfigKey(c.ProviderKey) == configKey);
        if (connector is null) return;

        var field = connector.ConfigFields.FirstOrDefault(f => f.Key == fieldKey);
        if (field is null) return;

        if (!_validationErrors.ContainsKey(configKey))
            _validationErrors[configKey] = [];
        while (_validationErrors[configKey].Count <= index)
            _validationErrors[configKey].Add([]);

        var conn = GetConnections(configKey);
        if (index >= conn.Count) return;

        var value = (GetConnectionField(conn[index], fieldKey) ?? "").Trim();
        var errors = _validationErrors[configKey][index];

        var httpContext = HttpContextAccessor.HttpContext;
        var userProvider = httpContext?.User.FindFirst("provider")?.Value ?? "";

        if (fieldKey == "personalAccessToken" && connector.ProviderKey == "azure-devops"
            && string.Equals(userProvider, "microsoft", StringComparison.OrdinalIgnoreCase))
        {
            errors.Remove(fieldKey);
            return;
        }

        if (field.Required && string.IsNullOrWhiteSpace(value))
        {
            errors[fieldKey] = $"{field.Label} is required.";
            return;
        }

        if (string.IsNullOrWhiteSpace(value))
        {
            errors.Remove(fieldKey);
            return;
        }

        if (fieldKey == "baseUrl" && !Uri.TryCreate(value, UriKind.Absolute, out _))
        {
            errors[fieldKey] = "Must be a valid URL (e.g. https://yourorg.atlassian.net).";
            return;
        }

        if (fieldKey == "email" && !value.Contains('@'))
        {
            errors[fieldKey] = "Must be a valid email address.";
            return;
        }

        errors.Remove(fieldKey);
    }

    private void AddConnection(ConnectorMeta connector)
    {
        var configKey = ToConfigKey(connector.ProviderKey);
        if (!_connections.ContainsKey(configKey))
            _connections[configKey] = [];

        var dict = new Dictionary<string, object?>
        {
            ["id"] = Guid.NewGuid().ToString("N"),
            ["enabled"] = true,
            [EmojiField] = connector.DefaultEmoji
        };
        foreach (var field in connector.ConfigFields)
        {
            if (field.InputKind == "checkbox")
            {
                dict[field.Key] = string.Equals(field.DefaultValue, "true", StringComparison.OrdinalIgnoreCase);
            }
            else
            {
                dict[field.Key] = field.DefaultValue ?? "";
            }
        }
        _connections[configKey].Add(dict);
        _expandedConnectors.Add(connector.ProviderKey);
        _hasUnsavedChanges = true;
    }

    private void RemoveConnection(string configKey, int index)
    {
        if (_connections.TryGetValue(configKey, out var list) && index < list.Count)
        {
            list.RemoveAt(index);
        }
        if (_validationErrors.TryGetValue(configKey, out var errors) && index < errors.Count)
        {
            errors.RemoveAt(index);
        }
    }

    private async Task RemoveConnectionWithConfirmAsync(string configKey, int index)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", "Remove this connection? This cannot be undone.");
        if (confirmed)
        {
            RemoveConnection(configKey, index);
            _hasUnsavedChanges = true;
        }
    }

    private string? GetFieldError(string configKey, int index, string field)
    {
        if (_validationErrors.TryGetValue(configKey, out var connErrors) && index < connErrors.Count)
        {
            return connErrors[index].TryGetValue(field, out var err) ? err : null;
        }
        return null;
    }

    private bool ValidateAll()
    {
        var httpContext = HttpContextAccessor.HttpContext;
        var userProvider = httpContext?.User.FindFirst("provider")?.Value ?? "";
        _validationErrors = new();
        var hasErrors = false;

        foreach (var connector in _connectorMetadata)
        {
            var configKey = ToConfigKey(connector.ProviderKey);
            var conns = GetConnections(configKey);
            var connErrors = new List<Dictionary<string, string?>>();

            foreach (var conn in conns)
            {
                var errors = new Dictionary<string, string?>();

                // Validate emoji field
                var emojiValue = GetConnectionField(conn, EmojiField);
                if (!string.IsNullOrEmpty(emojiValue) && !EmojiData.IsValidEmoji(emojiValue))
                {
                    errors[EmojiField] = "Emoji must be a single emoji character.";
                    hasErrors = true;
                }

                foreach (var field in connector.ConfigFields)
                {
                    var value = (GetConnectionField(conn, field.Key) ?? "").Trim();

                    // Skip PAT validation for Azure DevOps when signed in with Microsoft
                    if (field.Key == "personalAccessToken" && connector.ProviderKey == "azure-devops"
                        && string.Equals(userProvider, "microsoft", StringComparison.OrdinalIgnoreCase))
                        continue;

                    if (field.Required && string.IsNullOrWhiteSpace(value))
                    {
                        errors[field.Key] = $"{field.Label} is required.";
                        hasErrors = true;
                        continue;
                    }

                    if (string.IsNullOrWhiteSpace(value)) continue;

                    if (field.Key == "baseUrl" && !Uri.TryCreate(value, UriKind.Absolute, out _))
                    {
                        errors[field.Key] = "Must be a valid URL (e.g. https://yourorg.atlassian.net).";
                        hasErrors = true;
                    }

                    if (field.Key == "email" && !value.Contains('@'))
                    {
                        errors[field.Key] = "Must be a valid email address.";
                        hasErrors = true;
                    }
                }
                connErrors.Add(errors);
            }
            _validationErrors[configKey] = connErrors;
        }

        return !hasErrors;
    }

    private ProviderConfiguration BuildConfigFromConnections()
    {
        var config = new ProviderConfiguration
        {
            Preferences = _config.Preferences
        };

        config.AzureDevOps = DeserializeConnections<AzureDevOpsConnection>("azureDevOps");
        config.GitHub = DeserializeConnections<GitHubConnection>("github");
        config.Jira = DeserializeConnections<JiraConnection>("jira");
        config.MicrosoftTasks = DeserializeConnections<MicrosoftTasksConnection>("microsoftTasks");
        config.OutlookFlaggedMail = DeserializeConnections<OutlookFlaggedMailConnection>("outlookFlaggedMail");
        config.Trello = DeserializeConnections<TrelloConnection>("trello");
        config.ImapFlaggedMail = DeserializeConnections<ImapFlaggedMailConnection>("imapFlaggedMail");
        config.LinkedMicrosoftAccounts = _config.LinkedMicrosoftAccounts;

        return config;
    }

    private List<T> DeserializeConnections<T>(string configKey)
    {
        if (!_connections.TryGetValue(configKey, out var list)) return [];
        var json = System.Text.Json.JsonSerializer.Serialize(list, System.Text.Json.JsonSerializerOptions.Web);
        return System.Text.Json.JsonSerializer.Deserialize<List<T>>(json, System.Text.Json.JsonSerializerOptions.Web) ?? [];
    }

    private async Task SaveConfiguration()
    {
        if (!ValidateAll())
        {
            _statusMessage = "Fix the highlighted fields before saving.";
            _statusIsError = true;
            return;
        }

        _savingConfig = true;
        _statusMessage = null;
        StateHasChanged();

        try
        {
            var httpContext = HttpContextAccessor.HttpContext;
            if (httpContext is null) return;

            var userId = GetUserIdentityKey(httpContext.User);
            var configToSave = BuildConfigFromConnections();
            await ConfigStore.SaveAsync(userId, configToSave, CancellationToken.None);
            _config = await ConfigStore.LoadAsync(userId, CancellationToken.None);
            RebuildConnectionsDictionary();
            _statusMessage = "Configuration saved. Return to the Dashboard to see refreshed data.";
            _statusIsError = false;
            _hasUnsavedChanges = false;
        }
        catch (Exception ex)
        {
            _statusMessage = ex.Message;
            _statusIsError = true;
        }
        finally
        {
            _savingConfig = false;
            StateHasChanged();
        }
    }

    private async Task ExportConfig()
    {
        var configToExport = BuildConfigFromConnections();
        // Mask secrets
        foreach (var c in configToExport.AzureDevOps) c.PersonalAccessToken = MaskSecret(c.PersonalAccessToken);
        foreach (var c in configToExport.GitHub) c.PersonalAccessToken = MaskSecret(c.PersonalAccessToken);
        foreach (var c in configToExport.Jira) c.ApiToken = MaskSecret(c.ApiToken);
        foreach (var c in configToExport.Trello) { c.ApiKey = MaskSecret(c.ApiKey); c.Token = MaskSecret(c.Token); }

        var json = System.Text.Json.JsonSerializer.Serialize(configToExport, new System.Text.Json.JsonSerializerOptions
        {
            WriteIndented = true,
            PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase
        });

        var base64 = Convert.ToBase64String(System.Text.Encoding.UTF8.GetBytes(json));
        await JS.InvokeVoidAsync("PriorityHub.downloadFile", "priority-hub-config.json", "application/json", base64);

        _statusMessage = "Configuration exported (check your downloads).";
        _statusIsError = false;
    }

    private static string MaskSecret(string value) =>
        !string.IsNullOrWhiteSpace(value) ? new string('*', Math.Min(value.Length, 8)) : "";

    private static string GetUserIdentityKey(System.Security.Claims.ClaimsPrincipal user)
    {
        var email = user.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value;
        if (!string.IsNullOrWhiteSpace(email)) return email;
        var sub = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "unknown";
        var provider = user.FindFirst("provider")?.Value ?? "unknown";
        return $"{sub}_{provider}";
    }

    private static string ToConfigKey(string providerKey) =>
        providerKey switch
        {
            "azure-devops" => "azureDevOps",
            "github" => "github",
            "jira" => "jira",
            "microsoft-tasks" => "microsoftTasks",
            "outlook-flagged-mail" => "outlookFlaggedMail",
            "trello" => "trello",
            "imap-flagged-mail" => "imapFlaggedMail",
            _ => providerKey
        };

    private List<(string Id, string Label)> GetLinkedAccountOptions() =>
        _config.LinkedMicrosoftAccounts
            .Select(a => (a.Id, string.IsNullOrWhiteSpace(a.DisplayName) ? a.Email : $"{a.DisplayName} ({a.Email})"))
            .ToList();

    private async Task RemoveLinkedAccountAsync(string accountId)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", "Remove this linked Microsoft account?");
        if (!confirmed) return;

        _linkedAccountsLoading = true;
        try
        {
            var httpContext = HttpContextAccessor.HttpContext;
            if (httpContext is null) return;

            var client = new System.Net.Http.HttpClient();
            var request = new System.Net.Http.HttpRequestMessage(System.Net.Http.HttpMethod.Delete,
                $"/api/auth/link/microsoft/{accountId}");

            // Remove from local list immediately for UX responsiveness.
            _config.LinkedMicrosoftAccounts.RemoveAll(a =>
                string.Equals(a.Id, accountId, StringComparison.OrdinalIgnoreCase));

            _statusMessage = "Linked account removed.";
            _statusIsError = false;
        }
        catch (Exception ex)
        {
            _statusMessage = $"Failed to remove linked account: {ex.Message}";
            _statusIsError = true;
        }
        finally
        {
            _linkedAccountsLoading = false;
        }
    }

    private async Task HandleImportFileSelected(InputFileChangeEventArgs e)
    {
        _importPreview = null;
        _pendingImportConfig = null;
        _importError = null;

        var file = e.File;
        if (file.Size > 1 * 1024 * 1024)
        {
            _importError = "File is too large. The maximum size is 1 MB.";
            return;
        }

        try
        {
            using var stream = file.OpenReadStream(maxAllowedSize: 1 * 1024 * 1024);
            var imported = await System.Text.Json.JsonSerializer.DeserializeAsync<ProviderConfiguration>(
                stream,
                new System.Text.Json.JsonSerializerOptions
                {
                    PropertyNameCaseInsensitive = true
                });

            if (imported is null)
            {
                _importError = "The file could not be parsed as a valid configuration.";
                return;
            }

            _pendingImportConfig = imported;
            _importPreview = ComputeImportPreview(imported);
        }
        catch (System.Text.Json.JsonException)
        {
            _importError = "Invalid JSON. Please upload a file exported from Priority Hub.";
        }
        catch (Exception ex)
        {
            _importError = $"Could not read the file: {ex.Message}";
        }
    }

    private List<ImportPreviewEntry> ComputeImportPreview(ProviderConfiguration imported)
    {
        var preview = new List<ImportPreviewEntry>();

        void AddEntries<T>(List<T> importedList, string providerLabel, string providerKey,
            Func<T, string> getId, Func<T, string> getName, Func<T, bool> hasMaskedSecrets)
            where T : class
        {
            // Build existing ID set once for this provider
            var existingIds = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
            foreach (var jsonElem in _config.GetConnections(providerKey))
            {
                if (jsonElem.TryGetProperty("id", out var idProp))
                    existingIds.Add(idProp.GetString() ?? "");
            }

            foreach (var item in importedList)
            {
                var id = getId(item);
                var name = getName(item);
                var action = existingIds.Contains(id) ? ImportAction.Update : ImportAction.Add;
                preview.Add(new ImportPreviewEntry(name, providerLabel, action, hasMaskedSecrets(item)));
            }
        }

        AddEntries(imported.AzureDevOps, "Azure DevOps", "azure-devops",
            c => c.Id, c => string.IsNullOrWhiteSpace(c.Name) ? c.Id : c.Name,
            c => IsMasked(c.PersonalAccessToken));
        AddEntries(imported.GitHub, "GitHub", "github",
            c => c.Id, c => string.IsNullOrWhiteSpace(c.Name) ? c.Id : c.Name,
            c => IsMasked(c.PersonalAccessToken));
        AddEntries(imported.Jira, "Jira", "jira",
            c => c.Id, c => string.IsNullOrWhiteSpace(c.Name) ? c.Id : c.Name,
            c => IsMasked(c.ApiToken));
        AddEntries(imported.MicrosoftTasks, "Microsoft Tasks", "microsoft-tasks",
            c => c.Id, c => string.IsNullOrWhiteSpace(c.Name) ? c.Id : c.Name,
            _ => false);
        AddEntries(imported.OutlookFlaggedMail, "Outlook Flagged Mail", "outlook-flagged-mail",
            c => c.Id, c => string.IsNullOrWhiteSpace(c.Name) ? c.Id : c.Name,
            _ => false);
        AddEntries(imported.Trello, "Trello", "trello",
            c => c.Id, c => string.IsNullOrWhiteSpace(c.Name) ? c.Id : c.Name,
            c => IsMasked(c.ApiKey) || IsMasked(c.Token));
        AddEntries(imported.ImapFlaggedMail, "IMAP Flagged Mail", "imap-flagged-mail",
            c => c.Id, c => string.IsNullOrWhiteSpace(c.Name) ? c.Id : c.Name,
            c => IsMasked(c.Password));

        // Match by ID → Update; new ID → Add. No deep diff per spec.

        return preview;
    }

    private async Task ApplyImportAsync()
    {
        if (_pendingImportConfig is null) return;

        var imported = _pendingImportConfig;

        // Upsert each provider list
        UpsertConnections(imported.AzureDevOps, "azureDevOps");
        UpsertConnections(imported.GitHub, "github");
        UpsertConnections(imported.Jira, "jira");
        UpsertConnections(imported.MicrosoftTasks, "microsoftTasks");
        UpsertConnections(imported.OutlookFlaggedMail, "outlookFlaggedMail");
        UpsertConnections(imported.Trello, "trello");
        UpsertConnections(imported.ImapFlaggedMail, "imapFlaggedMail");

        // Preferences are intentionally skipped to preserve manual ordering.

        _importPreview = null;
        _pendingImportConfig = null;
        _importError = null;

        // Auto-save the imported configuration
        try
        {
            var httpContext = HttpContextAccessor.HttpContext;
            if (httpContext is null) return;

            var userId = GetUserIdentityKey(httpContext.User);
            var configToSave = BuildConfigFromConnections();
            await ConfigStore.SaveAsync(userId, configToSave, CancellationToken.None);
            _config = await ConfigStore.LoadAsync(userId, CancellationToken.None);
            RebuildConnectionsDictionary();
            _hasUnsavedChanges = false;
            _statusMessage = "Configuration imported and saved. Review your connectors below.";
            _statusIsError = false;
            _activeTab = "connectors";
        }
        catch (Exception ex)
        {
            _hasUnsavedChanges = true;
            _statusMessage = $"Import applied but save failed: {ex.Message}";
            _statusIsError = true;
            // Stay on Import/Export tab on failure
        }
    }

    private void UpsertConnections<T>(List<T> importedList, string configKey) where T : class
    {
        if (!_connections.TryGetValue(configKey, out var currentList))
        {
            currentList = [];
            _connections[configKey] = currentList;
        }

        // Build an index of current connections by id
        var idIndex = new Dictionary<string, int>(StringComparer.OrdinalIgnoreCase);
        for (var i = 0; i < currentList.Count; i++)
        {
            if (currentList[i].TryGetValue("id", out var idVal) && idVal is string idStr)
                idIndex[idStr] = i;
        }

        var importedJson = System.Text.Json.JsonSerializer.Serialize(importedList, System.Text.Json.JsonSerializerOptions.Web);
        var importedDicts = System.Text.Json.JsonSerializer.Deserialize<List<Dictionary<string, object?>>>(
            importedJson, System.Text.Json.JsonSerializerOptions.Web) ?? [];

        foreach (var dict in importedDicts)
        {
            if (dict.TryGetValue("id", out var idObj) && idObj is System.Text.Json.JsonElement idElem
                && idElem.ValueKind == System.Text.Json.JsonValueKind.String)
            {
                var id = idElem.GetString() ?? "";
                if (idIndex.TryGetValue(id, out var idx))
                {
                    // Merge: update each field from the imported dict into the existing entry
                    var existing = currentList[idx];
                    foreach (var kvp in dict)
                        existing[kvp.Key] = kvp.Value;
                }
                else
                {
                    // Insert: normalize JsonElement values to primitives
                    var normalized = NormalizeDict(dict);
                    currentList.Add(normalized);
                }
            }
        }
    }

    private static Dictionary<string, object?> NormalizeDict(Dictionary<string, object?> dict)
    {
        var result = new Dictionary<string, object?>();
        foreach (var kvp in dict)
        {
            result[kvp.Key] = kvp.Value is System.Text.Json.JsonElement elem
                ? elem.ValueKind switch
                {
                    System.Text.Json.JsonValueKind.String => elem.GetString(),
                    System.Text.Json.JsonValueKind.True => (object?)true,
                    System.Text.Json.JsonValueKind.False => false,
                    System.Text.Json.JsonValueKind.Number => elem.GetInt32(),
                    _ => elem.ToString()
                }
                : kvp.Value;
        }
        return result;
    }

    private void CancelImport()
    {
        _importPreview = null;
        _pendingImportConfig = null;
        _importError = null;
    }

    private static bool IsMasked(string value) =>
        !string.IsNullOrWhiteSpace(value) && value.All(c => c == '*');

    private sealed record ConnectorMeta(
        string ProviderKey, string DisplayName, string Description,
        string DefaultEmoji, ConnectorFieldSpec[] ConfigFields);

    private enum ImportAction { Add, Update, Unchanged }

    private sealed record ImportPreviewEntry(
        string Name, string Provider, ImportAction Action, bool HasMaskedSecrets);
}
