{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Priority Hub Backend",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "Build Priority Hub Backend",
      "program": "${workspaceFolder}/backend/PriorityHub.Api/bin/Debug/net10.0/PriorityHub.Api.dll",
      "cwd": "${workspaceFolder}/backend/PriorityHub.Api",
      "env": {
        "ASPNETCORE_URLS": "http://localhost:8787"
      },
      "console": "integratedTerminal",
      "stopAtEntry": false,
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "Now listening on:\\s+(https?://\\S+)"
      }
    },
    {
      "name": "Priority Hub Frontend",
      "type": "msedge",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/src",
      "preLaunchTask": "Run Priority Hub Web"
    },
    {
      "name": "Priority Hub Blazor",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "Build Priority Hub Blazor",
      "program": "${workspaceFolder}/backend/PriorityHub.Ui/bin/Debug/net10.0/PriorityHub.Ui.dll",
      "cwd": "${workspaceFolder}/backend/PriorityHub.Ui",
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      },
      "console": "integratedTerminal",
      "stopAtEntry": false,
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "Now listening on:\\s+(https?://\\S+)"
      }
    }
  ],
  "compounds": [
    {
      "name": "Priority Hub Full Stack",
      "configurations": ["Priority Hub Backend", "Priority Hub Frontend"]
    }
  ]
}